<Window x:Class="Warehouse.Views.ModalWins.WhModWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse.Views.ModalWins"
        mc:Ignorable="d"
        Title="Склад" Height="455" Width="360" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->

        <Label Grid.Row="0"
           Grid.Column="0"
           Content="Название склада:"
           VerticalAlignment="Center"
           Margin="0,0,10,5"/>

        <TextBox x:Name="tbName"
             Grid.Row="0"
             Grid.Column="1"
             Margin="0,0,0,5"
             MinWidth="200"/>

        <!-- Адрес -->

        <Label Grid.Row="1"
           Grid.Column="0"
           Content="Адрес склада:"
           VerticalAlignment="Center"
           Margin="0,0,10,5"/>

        <TextBox x:Name="tbAdress"
             Grid.Row="1"
             Grid.Column="1"
             Margin="0,0,0,5"/>

        <!-- Кнопки -->

        <StackPanel Grid.Row="2"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">

            <Button Content="OK"
                Width="80"
                Margin="0,0,5,0"
                Click="BtnOk_Click"/>

            <Button Content="Отмена"
                Width="80"
                Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
