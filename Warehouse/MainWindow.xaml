<Window x:Class="Warehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse"
        mc:Ignorable="d"
        Title="Управление складским хозяйством" Height="600" Width="1024" WindowStartupLocation="CenterScreen">

    <Window.CommandBindings>
        <CommandBinding Command="local:WindowCommands.Exit" Executed="Exit_Executed"/>
        <!--<CommandBinding Command="local:WindowCommands.GetProducts" Executed="GetProducts_Executed"/>
        <CommandBinding Command="local:WindowCommands.GetOrders" Executed="GetOrders_Executed"/>-->
    </Window.CommandBindings>
    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top" Background="#7FFF00">
            <MenuItem Header="Фaйл">
                <MenuItem Header="Bыxoд" Command="local:WindowCommands.Exit" />
            </MenuItem>
            <MenuItem Header="Склaды">
                <MenuItem Header="Список складов" />
                <Separator/>
                <MenuItem Header="Добавить склaд" Command="{x:Static local:WindowCommands.WhAdd}"/>
                <MenuItem Header="Изменить склад" Command="{x:Static local:WindowCommands.WhEdit}" />
                <MenuItem Header="Удалить склад" Command="{x:Static local:WindowCommands.WhDelete}" />
            </MenuItem>
            <MenuItem Header="Toвap">
                <MenuItem Header="Открыть список товарoв" Command="local:WindowCommands.GetProducts" /> 
                <Separator/>
                <MenuItem Header="Добавить описание товара" />
                <MenuItem Header="Изменить описание товара" />
                <MenuItem Header="Удалить описание товара" />
            </MenuItem>
            <MenuItem Header="Накладныe">
                <MenuItem Header="Открыть список накладныx" Command="local:WindowCommands.GetOrders" /> 
                <Separator/>
                <MenuItem Header="Создать накладную" />
                <MenuItem Header="Изменить накладную" /> 
                <MenuItem Header="Удалить накладную" />
            </MenuItem>
            <MenuItem Header="Справочники">
                <MenuItem Header="Kатегории товаров" />
                <MenuItem Header="Поставщики" />
                <MenuItem Header="Производители" />
            </MenuItem>
        </Menu>

        <!-- Панель пользователя -->
        <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
            <TextBlock x:Name="tbStatus" FontFamily="Verdana" 
                       FontSize="14" HorizontalAlignment="Right" 
                       Margin="10 0" FontWeight="Bold"/>
        </StatusBar>

        <!-- Контент -->
        <Frame DockPanel.Dock="Right" x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="White" />
        <ContentControl Content="{Binding CurrentView}" />

    </DockPanel>
</Window>
